# Firebase Configuration - Cultura
NEXT_PUBLIC_FIREBASE_API_KEY=your_api_key_here
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project.appspot.com
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id

# Firebase Configuration - Deporte
NEXT_PUBLIC_FIREBASE_DEPORTE_API_KEY=your_deporte_api_key_here
NEXT_PUBLIC_FIREBASE_DEPORTE_AUTH_DOMAIN=your_deporte_project.firebaseapp.com
NEXT_PUBLIC_FIREBASE_DEPORTE_PROJECT_ID=your_deporte_project_id
NEXT_PUBLIC_FIREBASE_DEPORTE_STORAGE_BUCKET=your_deporte_project.appspot.com
NEXT_PUBLIC_FIREBASE_DEPORTE_MESSAGING_SENDER_ID=your_deporte_sender_id
NEXT_PUBLIC_FIREBASE_DEPORTE_APP_ID=your_deporte_app_id
NEXT_PUBLIC_FIREBASE_DEPORTE_MEASUREMENT_ID=your_deporte_measurement_id

# Groq AI API Key (para Chat IA - GRATIS)
GROQ_API_KEY=your_groq_api_key_here

# ElevenLabs API Key (para Voz Española)
ELEVENLABS_API_KEY=your_elevenlabs_api_key_here

# Super Admin Credentials
NEXT_PUBLIC_SUPER_ADMIN_USER=your_super_admin_user_here
NEXT_PUBLIC_SUPER_ADMIN_PASSWORD=your_super_admin_password_here

# Resend — reportes de asistencia a encargados
RESEND_API_KEY=re_your_key_here
EMAIL_FROM="Área de Cultura <areacultura.cdr@correounivalle.edu.co>"
EMAIL_REPLY_TO=areacultura.cdr@correounivalle.edu.co
# URL pública de la app (imágenes en /public/email)
NEXT_PUBLIC_APP_URL=https://tu-dominio.vercel.app
# Opcional: override explícito para assets del correo
# EMAIL_ASSETS_BASE_URL=https://tu-dominio.vercel.app
# Logo cabecera en public/email (por defecto: header-vicerrectoria-cultura.png)
# EMAIL_HEADER_IMAGE=/email/mi-logo.png
# Secreto para POST /api/email/send-test
EMAIL_TEST_SECRET=genera_un_secreto_largo
